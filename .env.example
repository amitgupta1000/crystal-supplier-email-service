# Google Cloud Configuration
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Gmail Configuration
GMAIL_IMPERSONATE_USER=noreply@yourdomain.com
EMAIL_SENDER=noreply@yourdomain.com
EMAIL_RECIPIENTS=admin@yourdomain.com,team@yourdomain.com

# Database Configuration
# Development: SQLite with async support (aiosqlite)
# DATABASE_URL=sqlite+aiosqlite:///./jobs.db

# Production: PostgreSQL with asyncpg (async driver)
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://emailservice:password@localhost:5432/crystal_db
CLOUD_SQL_CONNECTION_NAME=project:region:instance-name

# Google Cloud Storage
GCS_BUCKET_NAME=crystal-supplier-email-data

# Generative AI
GOOGLE_GENAI_API_KEY=your-genai-api-key

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
APP_BASE_URL=http://localhost:3000

# Application Environment
ENVIRONMENT=development
# ENVIRONMENT=production

# Logging
LOG_LEVEL=INFO

# CORS Configuration (update for production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email Configuration
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY=300

# Scheduler Configuration
SCHEDULER_INTERVAL_MINUTES=1
REMINDER_THRESHOLD_MINUTES=120
CLOSURE_THRESHOLD_MINUTES=240

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
